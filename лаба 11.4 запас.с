    #include <stdio.h>
    #include <locale.h>
    #include <stdlib.h>


void sort(int **array,int n,int j)
{
    int buf;
    if(j % 2 == 0)
    {
        for(int i = 0;i<n;i++)
        {
            for(int a = 1;a<n,i+a<n;a++)
            {
                if(array[i][j]>array[i+a][j])
                {
                    buf = array[i][j];
                    array[i][j] = array[i+a][j];
                    array[i+a][j] = buf;
                }
            }
        }
    }
    else
    {
       for(int i = 0;i<n;i++)
        {
            for(int a = 1;a<n,i+a<n;a++)
            {
                if(array[i][j]<array[i+a][j])
                {
                    buf = array[i][j];
                    array[i][j] = array[i+a][j];
                    array[i+a][j] = buf;
                }
            }
        }
    }
    return;
}

int main()
{
    setlocale(LC_ALL,"");

        
    int n;
    void (*operation)(int **array ,int n,int j);
    //шаблон для матрицы динамической
        printf("Введите размерность матрицы.  ");
        scanf("%d", &n);
           

        int **array= (int**)malloc(n*sizeof(int));
        for(int i = 0;i < n;i++)
        {
            array[i] = (int*)malloc(n*sizeof(int));
        }
        //Заполнение матрицы
        printf("Заполните матрицу \n");

        for(int i = 0;i < n;i++)
        {
            for(int j = 0;j < n;j++)
            {
                 scanf("%d", &array[i][j]);
                    
            }
        }
        //Вывод исходной матрицы
        printf("Исходная матрица \n");

        for(int i = 0;i < n;i++)
        {
            for(int j = 0;j < n;j++)
            {
                printf("%3d",array[i][j]);
            }
            printf("\n");
        }
    operation = &sort;

    for(int j = 0;j<n;j++)
    {
        operation(array,n,j);
    }
    printf("отсортированная матрица \n");

    for(int i = 0;i < n;i++)
    {
        for(int j = 0;j < n;j++)
        {
            printf("%3d",array[i][j]);
        }
        printf("\n");
    }
        //Освобождение памяти
        for (int i = 0; i < n; i++)
        {
            free(array[i]);
        }
        free(array);
        return 0;
    }
