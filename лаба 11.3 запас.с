#include <stdio.h>
#include <locale.h>
#include <stdlib.h>


void sort(int **array,int n,int j)
{
    int buf;
    if(j % 2 == 0)
    {
        for(int i = 0;i<n;i++)
        {
            for(int a = 1;a<n,i+a<n;a++)
            {
                if(array[i][j]>array[i+a][j])
                {
                    buf = array[i][j];
                    array[i][j] = array[i+a][j];
                    array[i+a][j] = buf;
                }
            }
        }
    }
    else
    {
       for(int i = 0;i<n;i++)
        {
            for(int a = 1;a<n,i+a<n;a++)
            {
                if(array[i][j]<array[i+a][j])
                {
                    buf = array[i][j];
                    array[i][j] = array[i+a][j];
                    array[i+a][j] = buf;
                }
            }
        }
    }
}

void print(int **array,int n,int m)
{
    for(int i = 0;i < n;i++)
    {
        for(int j = 0;j < m;j++)
        {
            printf("%3d",array[i][j]);
        }
        printf("\n");
    }
}

void ins(int **array,int n,int m)
{
    for(int i = 0;i < n;i++)
    {
        for(int j = 0;j < m;j++)
        {
            printf("array[%d][%d] = ",i,j);
            scanf("%d", &array[i][j]);
        }
    }
}

void clean(int **array,int n)
{
    for (int i = 0; i < n; i++)
    {
        free(array[i]);
    }
    free(array);
}



int main()
{
    setlocale(LC_ALL,"");

        
    int n, m, number;
    void (*operation)(int **array ,int n,int j);
    void (*insert)(int **array ,int n,int m);
    void (*output)(int **array ,int n,int m);
    void (*cleaning)(int **array ,int n);

    printf("Введите размерность матрицы.  ");
    scanf("%d %d", &n,&m);
    printf("Введите колво матриц.  ");
    scanf("%d", &number);
           

    int **array= (int**)malloc(n*sizeof(int));
    for(int i = 0;i < n;i++)
    {
        array[i] = (int*)malloc(m*sizeof(int));
    }
      
    operation = &sort;
    insert = &ins;
    output = &print;
    cleaning = &clean;
    
    for(int a = 0;a<number;a++)
    {
        printf("\nМатрица %d:\n", (a+1));
        insert(array,n,m);
        output(array,n,m);
        printf("\nсортированная матрица.\n");
        for(int j = 0;j<n;j++)
        {
            operation(array,n,j);
        }
        output(array,n,m);
    }
    
   //Освобождение памяти
    cleaning(array,n);
    return 0;
    }
