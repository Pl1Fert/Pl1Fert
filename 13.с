int check(char str)
{
    if ((str >= 'a' && str <= 'z') || (str >= 'A' && str <= 'Z'))
            return 1;
        else
            return 0;
    
}
void find(char*str,int n)
{
    int i = 0,start,end,max = 0,maxstart,maxend;
    while(i<n)
    {
            while(str[i] == ' ')i++;
            start = i;
            while(check(str[i]))i++;
            end = i;
            if(!max)max = end - start;
            else if(max<end - start)
            {
                max = end - start;
                maxstart = start;
                maxend = end;
            }
    }
    //for(int i = maxstart;)
}
